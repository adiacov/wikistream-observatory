#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: bin/wikistream-dev <command>

Commands:
  build            Build or rebuild local service images explicitly
  up               Start live mode, building only if images are missing
  live             Alias for up
  replay           Start replay mode with bundled sample data
  down             Stop the compose stack
  clean-snapshots  Remove generated snapshot files
  prune-images     Remove dangling Docker images after repeated rebuilds
  test             Run the Python test suite with uv
  help             Show this help
USAGE
}

command="${1:-help}"
shift || true

case "$command" in
  build)
    docker compose build "$@"
    ;;
  up|live)
    docker compose up "$@"
    ;;
  replay)
    WIKISTREAM_MODE=replay docker compose up "$@"
    ;;
  down)
    docker compose down "$@"
    ;;
  clean-snapshots)
    rm -rf data/snapshots/*
    ;;
  prune-images)
    docker image prune "$@"
    ;;
  test)
    PYTHONPATH=. uv run pytest "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "Unknown command: $command" >&2
    usage >&2
    exit 2
    ;;
esac
