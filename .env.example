# WikiStream Observatory local configuration
#
# Copy to `.env` if you want to override Docker Compose defaults:
#
#   cp .env.example .env
#
# Local ports exposed by compose.yaml:
# - Dashboard: http://localhost:8501
# - Redpanda Kafka API for optional host debugging: localhost:19092
#
# Internal container-only addresses:
# - Kafka bootstrap for services: redpanda:9092
# - Snapshot path inside processor/dashboard containers: /app/data/snapshots
#
# Local file ownership:
# app containers run as HOST_UID:HOST_GID so generated bind-mounted snapshots
# are owned by your host user instead of root. The Makefile and bin helper set
# these automatically; set them manually here only if your environment needs it.
# Find values with: id -u && id -g
#
# No Wikimedia credentials, paid services, cloud account, or Kubernetes cluster
# are required. Live mode uses read-only public EventStreams access.

# Runtime mode.
# live: consume Wikimedia EventStreams RecentChanges.
# replay: publish bundled data/replay/recentchange_sample.jsonl as demo data.
WIKISTREAM_MODE=live
HOST_UID=1000
HOST_GID=1000

# Kafka / Redpanda.
# Keep redpanda:9092 for Docker Compose service-to-service traffic.
# Use localhost:19092 only from host-side debugging tools, not inside containers.
WIKISTREAM_KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
WIKISTREAM_RAW_TOPIC=raw_recentchange

# Local paths inside containers.
# Host bind mounts:
# - ./data/snapshots -> /app/data/snapshots
# - ./data/replay    -> /app/data/replay (read-only in ingestor)
WIKISTREAM_SNAPSHOT_PATH=/app/data/snapshots
WIKISTREAM_REPLAY_PATH=/app/data/replay/recentchange_sample.jsonl

# Wikimedia etiquette: set a descriptive User-Agent for live mode.
# If publishing or sharing a long-running deployment, replace contact with a real
# project/contact reference. The local MVP should remain polite and identifiable.
WIKISTREAM_USER_AGENT=wikistream-observatory-local/0.1 (contact: local-dev)

# Dashboard and freshness behavior.
# Live data is fresh only when the latest observed event is within this threshold.
WIKISTREAM_FRESHNESS_SECONDS=60
# Processor writes snapshots on this cadence in live mode; replay also flushes after publication.
WIKISTREAM_SNAPSHOT_INTERVAL_SECONDS=15
# Dashboard refresh/query target used by Streamlit views.
WIKISTREAM_DASHBOARD_REFRESH_SECONDS=15

# Domain-level bot spike signal defaults.
WIKISTREAM_SIGNAL_CURRENT_WINDOW_MINUTES=5
WIKISTREAM_SIGNAL_BASELINE_WINDOW_MINUTES=30
WIKISTREAM_SIGNAL_THRESHOLD_RATIO=3.0
WIKISTREAM_SIGNAL_MIN_EVENTS=20
WIKISTREAM_SIGNAL_TOP_BOTS_LIMIT=3

# Snapshot retention for generated live data.
# Bundled replay data under data/replay/ should be retained separately.
WIKISTREAM_LIVE_RETENTION_HOURS=6
